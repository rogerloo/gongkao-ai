# ============================================================
# 复制为 deploy/.env 并改成你的真实值(.env 已 gitignore,绝不入库)
#   cp .env.prod.example .env && vim .env
# ============================================================

# 你的域名(已解析 A 记录到本机公网 IP;Caddy 用它自动签 HTTPS 证书)
DOMAIN=app.example.com

# ---- Postgres(仅容器内部用;密码务必改强,别用默认)----
POSTGRES_USER=gongkao
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=gongkao

# ---- 后端 ----
# DATABASE_URL 的密码必须和上面 POSTGRES_PASSWORD 一致;host 用 compose 服务名 db
DATABASE_URL=postgresql+asyncpg://gongkao:change-me-to-a-strong-password@db:5432/gongkao
# JWT 签名密钥:≥32 字节随机串 —— 生成:openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32
# 允许的前端来源(同域部署 = 你的域名)
CORS_ORIGINS=["https://app.example.com"]

# ---- LLM / Embedding(仅后端,按需填;留空则对应能力降级)----
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=
