# 复制为 backend/.env(.env 不入库,铁律 1:LLM key 仅后端)

# LLM / Embedding(留空则相关功能在阶段 1 才接入)
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=

# 数据库(docker-compose 内通过环境变量覆盖为 db 主机名)
DATABASE_URL=postgresql+asyncpg://gongkao:gongkao@localhost:5432/gongkao

# CORS(JSON 数组)
CORS_ORIGINS=["http://localhost:5173"]
